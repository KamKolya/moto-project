# Express API server port
PORT=6969

# SQLite database location
# You can use an absolute path or leave as default relative path.
DB_PATH=./data/app.db

# Authentication switch (`true` = require login for protected API routes)
AUTH_ENABLED=true

# API authentication credentials
AUTH_EMAIL=admin@motosys.ua
AUTH_PASSWORD=change-this-password

# Secret used to sign auth tokens (set a strong random value in production)
AUTH_SECRET=change-this-secret-to-a-long-random-value
